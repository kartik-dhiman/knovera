APP_NAME="Knovera"
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
CHROMA_DIR=./data/chroma
SQLITE_PATH=./data/app.db

# Multilingual embedding model (50+ languages)
# For English-only use, you can switch to: sentence-transformers/all-MiniLM-L6-v2
# NOTE: Changing this requires re-ingesting all documents
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHUNK_SIZE=900
CHUNK_OVERLAP=150

OLLAMA_BASE_URL=http://localhost:11434
# Fast local model with good multilingual support
# For better quality (slower): qwen2.5:3b-instruct
OLLAMA_MODEL=qwen2.5:1.5b-instruct
RETRIEVAL_TOP_K=3
MAX_CONTEXT_CHARS=3500

ANONYMIZED_TELEMETRY=FALSE
